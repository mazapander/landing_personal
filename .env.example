CV_PUBLIC_BASE_URL=https://anderdata.es
CV_FILE_PATH=/private/cv/cv.pdf
CV_TOKEN_TTL_HOURS=72
CV_MAX_DOWNLOADS=5
CV_REQUEST_LIMIT_PER_HOUR=5
CV_REQUEST_WINDOW_MINUTES=60
